PORT=3000
TRUST_PROXY=false

# Cloudflare Turnstile (required for production security checks)
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Set to true only for local testing without Turnstile.
DISABLE_TURNSTILE=true

# SMTP email delivery (optional but recommended)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
CONTACT_TO_EMAIL=mdsuhailtab.1@gmail.com
CONTACT_FROM_EMAIL=

# Optional PostgreSQL storage for parameterized inserts
DATABASE_URL=
DATABASE_SSL=false
